meta {
  name: Verify no is_correct in student assessment response
  type: http
  seq: 1
}

get {
  url: {{base_url}}/api/v1/assessments/
  body: none
  auth: none
}

headers {
  Cookie: gyangrit_sessionid={{session_id}}
}

tests {
  test("response is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("SECURITY: is_correct not exposed to students", function() {
    const data = res.getBody();
    const assessments = Array.isArray(data) ? data : [data];
    assessments.forEach(assessment => {
      const questions = assessment.questions || [];
      questions.forEach(q => {
        q.options.forEach(opt => {
          expect(opt).to.not.have.property("is_correct",
            `SECURITY FAIL: is_correct found in option ${opt.id}`);
        });
      });
    });
  });
}
