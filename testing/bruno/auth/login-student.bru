meta {
  name: Login Student
  type: http
  seq: 1
}

post {
  url: {{base_url}}/api/v1/accounts/login/
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-CSRFToken: {{csrf_token}}
}

body:json {
  {
    "username": "student1",
    "password": "GyanGrit@2024"
  }
}

script:post-response {
  // Save session cookie for subsequent requests
  const cookie = res.headers['set-cookie'];
  if (cookie) {
    bru.setVar("session_id", cookie);
  }
}

tests {
  test("login returns 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("response has authenticated field", function() {
    expect(res.getBody()).to.have.property("authenticated");
  });
}
